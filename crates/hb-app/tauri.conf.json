{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hoardbook",
  "version": "0.1.0",
  "identifier": "net.hoardbook",
  "build": {
    "frontendDist": "ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hoardbook",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_OUTPUT_OF: cargo tauri signer generate -w ~/.tauri/hoardbook.key",
      "endpoints": [
        "https://github.com/fluxtheory/Hoardbook/releases/latest/download/latest.json"
      ]
    }
  }
}
